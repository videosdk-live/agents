# =============================================================================
# VideoSDK AI Agents — Environment Variables
# =============================================================================
# Copy this file to `.env` in the repository root and fill in the values for
# the providers you actually use. All variables are read via os.getenv().
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# VideoSDK Auth (REQUIRED — pick ONE of the two setups below)
# -----------------------------------------------------------------------------
# Setup A: Provide a ready-made auth token (generated from the VideoSDK dashboard)
VIDEOSDK_AUTH_TOKEN=

# Setup B: Provide API key + secret. The SDK will auto-mint a JWT at runtime
# and use it for meeting creation, join, recording, SIP, analytics, inference.
# (Used only when VIDEOSDK_AUTH_TOKEN is not set.)
VIDEOSDK_API_KEY=
VIDEOSDK_SECRET_KEY=


# -----------------------------------------------------------------------------
# Provider Keys (alphabetical — uncomment and set the ones you need)
# -----------------------------------------------------------------------------

# Anam (Avatar)
ANAM_API_KEY=

# Anthropic (LLM — Claude)
ANTHROPIC_API_KEY=

# AssemblyAI (STT)
ASSEMBLYAI_API_KEY=

# AWS (TTS — Polly)
AWS_ACCESS_KEY_ID=
AWS_DEFAULT_REGION=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Azure OpenAI (accessed via the openai plugin)
AZURE_OPENAI_AD_TOKEN=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=

# Azure Speech (STT / TTS)
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Azure Voice Live (Realtime)
AZURE_VOICE_LIVE_API_KEY=
AZURE_VOICE_LIVE_ENDPOINT=

# CambAI (TTS)
CAMBAI_API_KEY=

# Cartesia (STT/TTS)
CARTESIA_API_KEY=

# Cerebras (LLM)
CEREBRAS_API_KEY=

# CometAPI (TTS)
COMETAPI_API_KEY=

# Deepgram (STT / TTS)
DEEPGRAM_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# Gladia (STT)
GLADIA_API_KEY=

# Google (Gemini, Cloud TTS / STT)
GCLOUD_PROJECT=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_LOCATION=
GOOGLE_CLOUD_PROJECT=

# Groq (LLM)
GROQ_API_KEY=

# Hume AI (TTS)
HUMEAI_API_KEY=

# Inworld AI (TTS)
INWORLD_API_KEY=

# LMNT (TTS)
